# Supabase Configuration
# Frontend-safe values only
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Google OAuth Configuration
# Get these from Google Cloud Console -> APIs & Services -> Credentials
VITE_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
VITE_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Native redirect base for Capacitor builds
VITE_NATIVE_REDIRECT_BASE=https://your-app-domain.com

# Cloudflare Turnstile (publishable site key only)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Optional frontend build metadata
# VITE_APP_VERSION=1.2.3
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Server-only/local automation values
# Keep these in .env.local or your secret manager, never in tracked files.
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# INTERNAL_FUNCTION_SECRET=replace-with-a-long-random-secret
# INFLUENCER_DASHBOARD_SECRET=replace-with-a-long-random-secret

# Apple OAuth Configuration
# These should be set in Supabase secrets via the dashboard, not in .env
# APPLE_SERVICE_ID=com.your-company.your-app.web
# APPLE_TEAM_ID=YOUR_TEAM_ID
# APPLE_KEY_ID=YOUR_KEY_ID
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...keep in Supabase secrets...\n-----END PRIVATE KEY-----"
# APPLE_IOS_BUNDLE_ID=com.your-company.your-app

# AI Provider (set in Supabase project secrets, not frontend env)
# OPENAI_API_KEY=sk-...
# ELEVENLABS_API_KEY=...
#
# Cost guardrails (set these in Supabase project secrets, not frontend env)
# COST_KILL_SWITCH_ALL=false
# COST_KILL_SWITCH_TEXT=false
# COST_KILL_SWITCH_IMAGE=false
# COST_KILL_SWITCH_TTS=false
# COST_KILL_SWITCH_MUSIC=false
# COST_KILL_SWITCH_TRANSCRIPTION=false
# COST_KILL_SWITCH_VIDEO=false
# COST_KILL_SWITCH_ENDPOINTS=generate-companion-image,generate-rhythm-track
# COST_ALERT_WEBHOOK_URL=https://your-alert-endpoint.example/webhook
# COST_ALERT_WEBHOOK_BEARER_TOKEN=replace-me
# TURNSTILE_SECRET_KEY=your-turnstile-secret
# INFLUENCER_DASHBOARD_SECRET=use-a-random-32+-character-secret
